# ==============================================
# Environment Variables Template (MedBook Version)
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=medbook-microservices
ENVIRONMENT=development

# --- Database Credentials ---
DB_USER=admin
DB_PASSWORD=password
MONGODB_PASSWORD=password

# --- Service Ports ---
IDENTITY_SERVICE_PORT=5001
DOCTOR_SERVICE_PORT=5002
APPOINTMENT_SERVICE_PORT=5003
CHAT_SERVICE_PORT=5006
PROFILE_SERVICE_PORT=5010
SLOT_SERVICE_PORT=5011
GATEWAY_PORT=8080
FRONTEND_PORT=80

# --- gRPC Ports ---
DOCTOR_GRPC_PORT=50051
SLOT_GRPC_PORT=50052

# --- Service Discovery / Infra Wiring ---
EUREKA_SERVER_URL=http://eureka-server:8761/eureka
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_RABBIT_HOST=rabbitmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
NOTIFICATION_QUEUE=notification-delivery

# --- Keycloak & Security ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=clinic-realm
KEYCLOAK_CLIENT_ID=admin-cli
KC_HOSTNAME=localhost
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://keycloak:8080/realms/clinic-realm
KEYCLOAK_ISSUER=http://keycloak:8080/realms/clinic-realm
# Lấy secret từ Keycloak Dashboard -> Clients -> admin-cli -> Credentials
KEYCLOAK_ADMIN_CLIENT_SECRET=enter_keycloak_secret
# Dùng cho script tiện ích trong chat-service
KEYCLOAK_SECRET=enter_keycloak_secret

# --- Application Defaults ---
APP_FRONTEND_URL=http://frontend
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=123456
APP_SERVICES_PROFILE=http://profile-service:5010/profile
APP_SERVICES_APPOINTMENT=http://appointment-service:5003
DOCTOR_SERVICE_ID=doctor-service
SLOT_SERVICE_ID=slot-service
GRPC_METADATA_PORT_KEY=grpc.port
DOCTOR_DEFAULT_GRPC_PORT=50051
SLOT_DEFAULT_GRPC_PORT=50052
GRPC_CALL_TIMEOUT_SECONDS=5
APPOINTMENT_SAGA_OUTBOX_PUBLISH_INTERVAL_MS=1000
APPOINTMENT_SAGA_REPLY_LISTENER_AUTO_STARTUP=true
DOCTOR_MESSAGING_LISTENERS_AUTO_STARTUP=true
SLOT_MESSAGING_LISTENERS_AUTO_STARTUP=true

# --- Chat Service ---
CHAT_SERVICE_HOST=0.0.0.0
MONGO_URL=mongodb://admin:password@mongodb:27017/chat_db?authSource=admin
PROFILE_SERVICE_URL=http://profile-service:5010
SOCKET_PATH=/chat/socket.io

# --- Cloudinary (Image Uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- AI Configuration ---
# ĐÃ DI CHUYỂN API KEY VÀO ĐÂY ĐỂ BẢO MẬT
# HÃY COPY KEY THẬT VÀO FILE .env CỦA BẠN (FILE NÀY SẼ BỊ GIT IGNORE)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
APP_OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
